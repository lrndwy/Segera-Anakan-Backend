NODE_ENV=development
APP_NAME=pltu-app-hono
API_PREFIX=/api/v1

# Port aplikasi di dalam container / proses Node
PORT=3000
# Port yang di-publish ke host (docker-compose: app)
APP_HOST_PORT=3100

# Port yang di-publish ke host (docker-compose)
POSTGRES_PORT=5433
REDIS_PORT=6380
MINIO_API_PORT=9100
MINIO_CONSOLE_PORT=9101

# Koneksi dari host (npm run dev di luar Docker)
DATABASE_URL=postgresql://pltu:pltu@localhost:5433/pltu_app
TEST_DATABASE_URL=postgresql://pltu:pltu@localhost:5433/pltu_app_test
# Koneksi dari container app/worker (nama service Docker)
REDIS_URL=redis://redis:6379

POSTGRES_USER=pltu
POSTGRES_PASSWORD=pltu
POSTGRES_DB=pltu_app

JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
BCRYPT_SALT_ROUNDS=12

CORS_ORIGINS=http://localhost:3100,http://localhost:5173
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Endpoint internal Docker (app/worker → minio)
STORAGE_ENDPOINT=http://minio:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=pltu-files
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin123
STORAGE_FORCE_PATH_STYLE=true
# URL publik dari browser/host — gunakan MINIO_API_PORT
STORAGE_PUBLIC_BASE_URL=http://localhost:9100

EMAIL_QUEUE_NAME=email
EMAIL_FROM=no-reply@example.com

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!

# BMKG — prakiraan cuaca (digunakan Rob Guardian sync)
BMKG_API_URL=https://api.bmkg.go.id/publik/prakiraan-cuaca

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# Override untuk menjalankan test dari host (harus sesuai port di atas)
TEST_REDIS_URL=redis://localhost:6380
TEST_STORAGE_ENDPOINT=http://localhost:9100
